# ============================================
# DATABASE (MySQL)
# ============================================
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/opentomy"

# ============================================
# AUTH (NextAuth + Keycloak)
# ============================================
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Keycloak OAuth2 client
# - Create a client in Keycloak Admin → Realm → Clients → Create
# - Set "Access Type" = confidential, enable "Standard Flow"
# - Add redirect URI: http://localhost:3000/api/auth/callback/keycloak
KEYCLOAK_CLIENT_ID="opentomy"
KEYCLOAK_CLIENT_SECRET="your-client-secret-from-keycloak"
# Format: http(s)://<keycloak-host>/realms/<realm-name>
KEYCLOAK_ISSUER="http://localhost:8080/realms/opentomy"

# ============================================
# STRIPE
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."

# ============================================
# FILE STORAGE (S3 / compatible)
# ============================================
S3_BUCKET_NAME="opentomy-files"
S3_REGION="us-east-1"
# S3_ENDPOINT: leave empty for AWS, set for MinIO / Cloudflare R2 / etc.
S3_ENDPOINT=""
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# ============================================
# CRYPTO KEYS
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use the /gen-keys slash command
# ============================================
APP_MASTER_KEY="64-char-hex-string-here"
SERVER_DECRYPT_SECRET="64-char-hex-string-here"
