# ============================================
# BACKEND API
# ============================================
# Full base URL of the deployed backend (no trailing slash)
# Example: https://api.opentomy.com/famaster/v1/opentomy
NEXT_PUBLIC_API_URL="http://localhost:8080/famaster/v1/opentomy"

# ============================================
# AUTH (NextAuth + Keycloak)
# ============================================
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Keycloak OAuth2 client
# - Create a client in Keycloak Admin → Realm → Clients → Create
# - Set "Access Type" = confidential, enable "Standard Flow"
# - Add redirect URI: http://localhost:3000/api/auth/callback/keycloak
KEYCLOAK_CLIENT_ID="opentomy"
KEYCLOAK_CLIENT_SECRET="your-client-secret-from-keycloak"
# Format: http(s)://<keycloak-host>/realms/<realm-name>
KEYCLOAK_ISSUER="http://localhost:8080/realms/opentomy"
