# Opentomy crypto keys (copy from opentomy .env)
APP_MASTER_KEY=<64-char hex>
SERVER_DECRYPT_SECRET=<64-char hex>

# famaster MySQL connection
FAMASTER_DB_HOST=localhost
FAMASTER_DB_PORT=3306
FAMASTER_DB_NAME=famaster
FAMASTER_DB_USER=root
FAMASTER_DB_PASS=

# Output directory for generated .tomy files
OUTPUT_DIR=./output

# GCS upload (optional — copy from opentomy .env.production)
GCS_KEY_BASE64=<base64 service account JSON>
GCS_BUCKET=faquiz2
GCS_FILE_PREFIX=opentomy/
